<div class="bookie-page">

  {{! ── Header ── }}
  <div class="bookie-header">
    <div class="bookie-header-title">
      <span class="bookie-header-trophy">🏆</span>
      <h1>Bookie</h1>
    </div>
    <div class="bookie-balance-badge">
      <span class="bookie-balance-label">Your balance</span>
      <span class="bookie-balance-amount">{{this.balance}} {{this.currency}}</span>
    </div>
  </div>

  {{! ── Tabs ── }}
  <div class="bookie-tabs">
    <button class="bookie-tab {{if (eq this.activeTab 'matches') 'active'}}"
            {{on "click" (fn this.setTab "matches")}}>Open events</button>
    <button class="bookie-tab {{if (eq this.activeTab 'results') 'active'}}"
            {{on "click" (fn this.setTab "results")}}>Results</button>
    <button class="bookie-tab {{if (eq this.activeTab 'wallet') 'active'}}"
            {{on "click" (fn this.setTab "wallet")}}>My wallet</button>
    <button class="bookie-tab {{if (eq this.activeTab 'leaderboard') 'active'}}"
            {{on "click" (fn this.setTab "leaderboard")}}>Standings</button>
    <button class="bookie-tab {{if (eq this.activeTab 'rules') 'active'}}"
            {{on "click" (fn this.setTab "rules")}}>Rules</button>
    {{#if this.currentUser.staff}}
      <button class="bookie-tab bookie-tab-admin {{if (eq this.activeTab 'admin') 'active'}}"
              {{on "click" (fn this.setTab "admin")}}>
        {{d-icon "wrench"}} Admin
      </button>
    {{/if}}
  </div>

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Open matches                                }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (eq this.activeTab "matches")}}
  <div class="bookie-panel">
    {{#if this.matches.length}}
      <div class="bookie-matches-grid">
        {{#each this.matches as |match|}}
          <div class="bookie-match-card {{if match.userBet 'has-bet'}}">

            <div class="bookie-match-teams">
              <span class="bookie-team">{{match.home_team}}</span>
              <span class="bookie-vs">vs</span>
              <span class="bookie-team">{{match.away_team}}</span>
            </div>

            {{#if match.userBet}}
              {{! Already placed a bet }}
              <div class="bookie-existing-bet">
                <div class="bookie-bet-badge bet-{{match.userBet.choice}}">
                  {{match.userBetLabel}}
                  &nbsp;·&nbsp;{{match.userBet.amount}} {{this.currency}}
                  &nbsp;@&nbsp;{{match.userBet.odds}}x
                  &nbsp;→&nbsp;{{match.userBet.potential_payout}} {{this.currency}}
                </div>
                {{#if match.canBet}}
                  <button class="btn btn-small btn-danger"
                          {{on "click" (fn this.cancelBet match)}}>
                    Cancel bet
                  </button>
                {{/if}}
              </div>
            {{else if match.canBet}}
              {{! Bet form }}
              <div class="bookie-bet-form">
                <div class="bookie-odds-row">
                  <button class="bookie-odds-btn {{if (eq match.selectedChoice 'home') 'selected'}}"
                          {{on "click" (fn this.selectChoice match "home")}}>
                    <span class="bookie-odds-team">{{match.home_team}}</span>
                    <span class="bookie-odds-value">{{match.odds_home}}</span>
                  </button>
                  <button class="bookie-odds-btn {{if (eq match.selectedChoice 'draw') 'selected'}}"
                          {{on "click" (fn this.selectChoice match "draw")}}>
                    <span class="bookie-odds-team">Draw</span>
                    <span class="bookie-odds-value">{{match.odds_draw}}</span>
                  </button>
                  <button class="bookie-odds-btn {{if (eq match.selectedChoice 'away') 'selected'}}"
                          {{on "click" (fn this.selectChoice match "away")}}>
                    <span class="bookie-odds-team">{{match.away_team}}</span>
                    <span class="bookie-odds-value">{{match.odds_away}}</span>
                  </button>
                </div>

                {{#if match.selectedChoice}}
                  <div class="bookie-amount-row">
                    <input class="bookie-amount-input"
                           type="number" min="10" max="{{this.balance}}"
                           placeholder="Amount (min 10)"
                           value={{match.betAmount}}
                           {{on "input" (fn this.setAmount match)}} />
                    {{#if match.betAmount}}
                      <span class="bookie-payout-preview">
                        Win: {{match.calcPayout}} {{this.currency}}
                      </span>
                    {{/if}}
                    <button class="btn btn-primary bookie-place-bet"
                            disabled={{match.betDisabled}}
                            {{on "click" (fn this.placeBet match)}}>
                      Place bet
                    </button>
                  </div>
                {{/if}}

                {{#if match.betError}}
                  <div class="bookie-error">{{match.betError}}</div>
                {{/if}}
              </div>
            {{else}}
              <div class="bookie-closed-notice">Betting closed for this event</div>
            {{/if}}

            <div class="bookie-match-deadline">Closes: {{match.formattedDeadline}}</div>

          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="bookie-empty">
        No events open for betting right now — check back soon!
      </div>
    {{/if}}
  </div>
  {{/if}}

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Results                                     }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (eq this.activeTab "results")}}
  <div class="bookie-panel">
    <div class="bookie-standings-tabs bookie-results-tabs">
      <button class="bookie-standings-tab {{if (eq this.resultsSubTab 'my-results') 'active'}}"
              {{on "click" (fn this.setResultsSubTab "my-results")}}>
        My results
      </button>
      <button class="bookie-standings-tab {{if (eq this.resultsSubTab 'stats') 'active'}}"
              {{on "click" (fn this.setResultsSubTab "stats")}}>
        Stats
      </button>
    </div>

    {{#if (eq this.resultsSubTab "my-results")}}
      {{#if this.settledMatches.length}}
        <div class="bookie-results-list">
          {{#each this.settledMatches as |match|}}
            <div class="bookie-result-row {{if match.detailsExpanded 'is-expanded'}} {{if match.hasLeagueBreakdown 'has-breakdown'}}">
              <div class="bookie-result-main">
                <div class="bookie-result-teams">
                  {{match.home_team}} vs {{match.away_team}}
                </div>

                <div class="bookie-result-trailing">
                  {{#if match.userBet}}
                    <div class="bookie-result-outcome">
                      {{match.resultText}}
                    </div>
                    <div class="bookie-result-summary">
                      <div class="bookie-result-score {{match.coinDeltaClass}}">
                        {{match.coinDeltaText}}
                      </div>
                      {{#if match.hasLeaguePoints}}
                        <div class="bookie-result-score-divider"></div>
                        <div class="bookie-result-score {{match.pointsDeltaClass}}">
                          {{match.pointsDeltaText}}
                        </div>
                      {{/if}}
                    </div>
                  {{else}}
                    <div class="bookie-result-outcome">
                      {{match.resultText}}
                    </div>
                  {{/if}}

                  {{#if match.hasLeagueBreakdown}}
                    <button class="bookie-result-toggle"
                            type="button"
                            aria-expanded={{if match.detailsExpanded "true" "false"}}
                            {{on "click" (fn this.toggleResultDetails match)}}>
                      {{d-icon (if match.detailsExpanded "angle-up" "angle-down")}}
                    </button>
                  {{/if}}
                </div>
              </div>

              {{#if (and match.detailsExpanded match.hasLeagueBreakdown)}}
                <div class="bookie-result-breakdown">
                  {{#each match.leaguePointsBreakdown as |entry|}}
                    <div class="bookie-result-breakdown-item">
                      +{{entry.points}} {{entry.label}}
                    </div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <div class="bookie-empty">No settled events yet.</div>
      {{/if}}
    {{else}}
      {{#if this.resultsHasStats}}
        <div class="bookie-results-stats">
          <div class="bookie-results-stats-grid">
            <div class="bookie-stats-card">
              <div class="bookie-stats-card-label">Hit rate</div>
              <div class="bookie-stats-card-value">{{this.resultsHitRateText}}</div>
            </div>

            <div class="bookie-stats-card">
              <div class="bookie-stats-card-label">Current streak</div>
              <div class="bookie-stats-card-value">{{this.resultsSummary.current_streak}}</div>
            </div>

            <div class="bookie-stats-card">
              <div class="bookie-stats-card-label">Best streak</div>
              <div class="bookie-stats-card-value">{{this.resultsSummary.best_streak}}</div>
            </div>

            <div class="bookie-stats-card">
              <div class="bookie-stats-card-label">League points</div>
              <div class="bookie-stats-card-value">{{this.resultsLeaguePointsText}}</div>
            </div>
          </div>

          <div class="bookie-stats-panel">
            <div class="bookie-stats-panel-header">
              <div>
                <h3 class="bookie-stats-panel-title">Balance over time</h3>
                <p class="bookie-stats-panel-desc">Your coin balance after recent settled events.</p>
              </div>
              <span class="bookie-stats-panel-meta">Last {{this.resultsPointsTimeline.length}} settled events</span>
            </div>

            <BookieResultsChart @points={{this.resultsPointsTimeline}} @currency={{this.currency}} />
          </div>

          <div class="bookie-results-stats-lower">
            <div class="bookie-stats-panel">
              <div class="bookie-stats-panel-header">
                <div>
                  <h3 class="bookie-stats-panel-title">Prediction breakdown</h3>
                  <p class="bookie-stats-panel-desc">How often you picked the right outcome.</p>
                </div>
              </div>

              <div class="bookie-stats-breakdown-bar" aria-hidden="true">
                <div
                  class="bookie-stats-breakdown-segment is-win"
                  style={{concat "width: " this.resultsCorrectWidth "%;"}}
                ></div>
                <div
                  class="bookie-stats-breakdown-segment is-loss"
                  style={{concat "width: " this.resultsWrongWidth "%;"}}
                ></div>
              </div>

              <div class="bookie-stats-breakdown-legend">
                <div class="bookie-stats-breakdown-item">
                  <span class="bookie-stats-breakdown-dot is-win"></span>
                  <span>Correct</span>
                  <strong>{{this.resultsWins}}</strong>
                </div>
                <div class="bookie-stats-breakdown-item">
                  <span class="bookie-stats-breakdown-dot is-loss"></span>
                  <span>Wrong</span>
                  <strong>{{this.resultsLosses}}</strong>
                </div>
              </div>
            </div>

            <div class="bookie-stats-panel">
              <div class="bookie-stats-panel-header">
                <div>
                  <h3 class="bookie-stats-panel-title">Recent form</h3>
                  <p class="bookie-stats-panel-desc">{{this.resultsRecentFormSummary}}</p>
                </div>
              </div>

              <div class="bookie-stats-form-row">
                {{#each this.resultsRecentForm as |entry|}}
                  <div class="bookie-stats-form-chip {{if (eq entry.result 'W') 'is-win' 'is-loss'}}">
                    {{entry.result}}
                  </div>
                {{/each}}
              </div>
            </div>
          </div>

          <div class="bookie-stats-panel">
            <div class="bookie-stats-panel-header">
              <div>
                <h3 class="bookie-stats-panel-title">Your betting profile</h3>
                <p class="bookie-stats-panel-desc">A quick read on your Bookie performance so far.</p>
              </div>
            </div>

            <div class="bookie-stats-summary-list">
              <div class="bookie-stats-summary-row">
                <span>Total settled bets</span>
                <strong>{{this.resultsSummary.total_settled_bets}}</strong>
              </div>
              <div class="bookie-stats-summary-row">
                <span>Coin profit/loss</span>
                <strong class="{{this.resultsCoinDeltaClass}}">{{this.resultsCoinDeltaText}}</strong>
              </div>
              <div class="bookie-stats-summary-row">
                <span>Average winning odds</span>
                <strong>{{this.resultsAverageWinningOddsText}}</strong>
              </div>
              <div class="bookie-stats-summary-row">
                <span>Biggest win</span>
                <strong class="bet-status-won">{{this.resultsBiggestWinText}}</strong>
              </div>
            </div>
          </div>
        </div>
      {{else}}
        <div class="bookie-empty">No personal stats yet — settle a few events first.</div>
      {{/if}}
    {{/if}}
  </div>
  {{/if}}

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Wallet                                      }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (eq this.activeTab "wallet")}}
  <div class="bookie-panel">
    <div class="bookie-wallet-balance">
      Balance: <strong>{{this.walletBalance}} {{this.currency}}</strong>
    </div>
    <h3>Recent transactions</h3>
    {{#if this.walletTransactions.length}}
      <table class="bookie-tx-table">
        <thead>
          <tr><th>Date</th><th>Description</th><th>Amount</th></tr>
        </thead>
        <tbody>
          {{#each this.walletTransactions as |tx|}}
            <tr class="{{if tx.isPositive 'tx-positive' 'tx-negative'}}">
              <td>{{tx.formattedDate}}</td>
              <td>{{tx.description}}</td>
              <td class="tx-amount">
                {{#if tx.isPositive}}+{{/if}}{{tx.amount}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="bookie-empty">No transactions yet.</div>
    {{/if}}
  </div>
  {{/if}}

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Standings                                   }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (eq this.activeTab "leaderboard")}}
  <div class="bookie-panel bookie-standings-panel">

    {{! Sub-tab navigation }}
    <div class="bookie-standings-tabs">
      <button class="bookie-standings-tab {{if (eq this.standingsTab 'league-table') 'active'}}"
              {{on "click" (fn this.setStandingsTab "league-table")}}>
        League Table
      </button>
      <button class="bookie-standings-tab {{if (eq this.standingsTab 'richest-gooner') 'active'}}"
              {{on "click" (fn this.setStandingsTab "richest-gooner")}}>
        Richest Gooner
      </button>
    </div>

    {{! ── League Table ── }}
    {{#if (eq this.standingsTab "league-table")}}
    <div class="bookie-standings-card">
      <div class="bookie-standings-card-header">
        <div>
          <h2 class="bookie-standings-title">League Table</h2>
          <p class="bookie-standings-desc">Resets every two months. Rewards form, consistency and streaks.</p>
        </div>
        {{#if this.currentPeriodLabel}}
          <span class="bookie-period-pill">Period: {{this.currentPeriodLabel}}</span>
        {{/if}}
      </div>

      {{#if this.leaguePodium.length}}
        {{! Podium: top 3 — order: 2nd left, 1st centre, 3rd right via CSS }}
        <div class="bookie-podium">
          {{#each this.leaguePodium as |entry i|}}
            <div class="bookie-podium-card rank-{{entry.rank}}">
              <span class="bookie-podium-rank-num">{{entry.rank}}</span>
              <span class="bookie-podium-medal">
                {{#if (eq entry.rank 1)}}🥇{{else if (eq entry.rank 2)}}🥈{{else}}🥉{{/if}}
              </span>
              <span class="bookie-podium-rank-pill">
                {{#if (eq entry.rank 1)}}1st{{else if (eq entry.rank 2)}}2nd{{else}}3rd{{/if}}
              </span>
              <span class="bookie-podium-name">{{entry.username}}</span>
              <span class="bookie-podium-value">{{entry.points}} pts</span>
            </div>
          {{/each}}
        </div>

        {{! Rest of the table (#4+) }}
        {{#if this.leagueRest.length}}
        <table class="bookie-lb-table bookie-standings-rest">
          <tbody>
            {{#each this.leagueRest as |entry|}}
              <tr>
                <td class="lb-rank-cell">#{{entry.rank}}</td>
                <td><a href="/u/{{entry.username}}">{{entry.username}}</a></td>
                <td class="lb-balance">{{entry.points}} pts</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
      {{else}}
        <div class="bookie-empty">No points yet this period — place your first bet!</div>
      {{/if}}

      {{! ── Previous periods ── }}
      {{#if this.periodHistory.length}}
        <div class="bookie-prev-period">
          <h3 class="bookie-prev-period-title">Previous periods</h3>

          {{! Period selector pills }}
          <div class="bookie-period-selector">
            {{#each this.periodHistory as |period|}}
              <button
                class="bookie-period-pill-btn {{if (eq this.effectivePeriodKey period.period_key) 'active'}}"
                {{on "click" (fn this.selectPeriod period.period_key)}}>
                {{period.label}}
              </button>
            {{/each}}
          </div>

          {{! Top 3 for selected period }}
          {{#if this.selectedPeriod}}
            <div class="bookie-prev-period-list">
              {{#each this.selectedPeriod.top3 as |entry|}}
                <div class="bookie-prev-period-row">
                  <span class="bookie-prev-medal">
                    {{#if (eq entry.rank 1)}}🥇{{else if (eq entry.rank 2)}}🥈{{else}}🥉{{/if}}
                  </span>
                  <span class="bookie-prev-name">
                    <a href="/u/{{entry.username}}">{{entry.username}}</a>
                  </span>
                  <span class="bookie-prev-pts">{{entry.points}} pts</span>
                </div>
              {{/each}}
            </div>
          {{/if}}
        </div>
      {{/if}}

    </div>
    {{/if}}

    {{! ── Richest Gooner ── }}
    {{#if (eq this.standingsTab "richest-gooner")}}
    <div class="bookie-standings-card">
      <div class="bookie-standings-card-header">
        <div>
          <h2 class="bookie-standings-title">Richest Gooner</h2>
          <p class="bookie-standings-desc">Runs across the full season. Ranked by total coins.</p>
        </div>
        <span class="bookie-period-pill">Season-long ranking</span>
      </div>

      {{#if this.richestPodium.length}}
        <div class="bookie-podium">
          {{#each this.richestPodium as |entry|}}
            <div class="bookie-podium-card rank-{{entry.rank}}">
              <span class="bookie-podium-rank-num">{{entry.rank}}</span>
              <span class="bookie-podium-medal">
                {{#if (eq entry.rank 1)}}🥇{{else if (eq entry.rank 2)}}🥈{{else}}🥉{{/if}}
              </span>
              <span class="bookie-podium-rank-pill">
                {{#if (eq entry.rank 1)}}1st{{else if (eq entry.rank 2)}}2nd{{else}}3rd{{/if}}
              </span>
              <span class="bookie-podium-name">{{entry.username}}</span>
              <span class="bookie-podium-value">{{entry.balance}} {{this.currency}}</span>
            </div>
          {{/each}}
        </div>

        {{#if this.richestRest.length}}
        <table class="bookie-lb-table bookie-standings-rest">
          <tbody>
            {{#each this.richestRest as |entry|}}
              <tr>
                <td class="lb-rank-cell">#{{entry.rank}}</td>
                <td><a href="/u/{{entry.username}}">{{entry.username}}</a></td>
                <td class="lb-balance">{{entry.balance}} {{this.currency}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
      {{else}}
        <div class="bookie-empty">No data yet — place your first bet!</div>
      {{/if}}
    </div>
    {{/if}}

  </div>
  {{/if}}

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Rules                                       }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (eq this.activeTab "rules")}}
  <div class="bookie-panel bookie-rules-panel">

    <div class="bookie-rules-intro">
      Bookie runs two parallel competitions. Both are purely virtual — no real money involved.
      Every member starts with {{this.currency}} to play with. Good luck! ⚽
    </div>

    {{! League Table }}
    <div class="bookie-rules-section">
      <div class="bookie-rules-section-header">
        <span class="bookie-rules-icon">🏆</span>
        <h2 class="bookie-rules-title">League Table</h2>
        <span class="bookie-period-pill">Resets every two months</span>
      </div>
      <p class="bookie-rules-tagline">Rewards picking accuracy, consistency and hot streaks.</p>

      <h3 class="bookie-rules-subheading">How points are earned</h3>
      <div class="bookie-rules-grid">
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts">+2</span>
          <div>
            <strong>Participation</strong>
            <span>Placing any bet on an event</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts">+10</span>
          <div>
            <strong>Correct pick</strong>
            <span>Your predicted outcome was right</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts">+odds bonus</span>
          <div>
            <strong>Odds bonus</strong>
            <span>Correct pick on a longer shot earns extra pts — calculated as <em>round((odds − 1) × 4)</em>. A 3.50 draw pays +10 pts on top of the base reward.</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts">+8 / +18 / +35</span>
          <div>
            <strong>Streak bonus</strong>
            <span>3 correct picks in a row: <strong>+8</strong> · 5 in a row: <strong>+18</strong> · 8 in a row: <strong>+35</strong></span>
          </div>
        </div>
      </div>

      <h3 class="bookie-rules-subheading">Periods</h3>
      <p class="bookie-rules-body">
        The league table resets every two months: Aug–Sep · Oct–Nov · Dec–Jan · Feb–Mar · Apr–May.
        At the end of each period the top 3 are snapshotted — you can view previous winners in the Standings tab.
      </p>

      <h3 class="bookie-rules-subheading">Important notes</h3>
      <p class="bookie-rules-body">
        Bet size does not affect your points. A minimum 10-coin bet on an event earns the same points as a max bet.
        The league table is purely about picking the right outcome, not risk-taking.
      </p>
    </div>

    {{! Richest Gooner }}
    <div class="bookie-rules-section">
      <div class="bookie-rules-section-header">
        <span class="bookie-rules-icon">💰</span>
        <h2 class="bookie-rules-title">Richest Gooner</h2>
        <span class="bookie-period-pill">Season-long</span>
      </div>
      <p class="bookie-rules-tagline">Ranked by your current coin balance. Runs all season — never resets.</p>

      <h3 class="bookie-rules-subheading">How coins work</h3>
      <div class="bookie-rules-grid">
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts bookie-rules-pts--start">1,000</span>
          <div>
            <strong>Starting balance</strong>
            <span>Every member begins the season with 1,000 {{this.currency}}</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts bookie-rules-pts--bonus">+100</span>
          <div>
            <strong>Weekly bonus</strong>
            <span>100 free {{this.currency}} deposited every Monday — keep coming back!</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts bookie-rules-pts--win">Win</span>
          <div>
            <strong>Bet winnings</strong>
            <span>Correct bets pay out at the quoted odds. A 100-coin bet at 3.50 returns 350 coins.</span>
          </div>
        </div>
        <div class="bookie-rules-row">
          <span class="bookie-rules-pts bookie-rules-pts--loss">Loss</span>
          <div>
            <strong>Losing bets</strong>
            <span>Your staked coins are deducted when a bet loses. Budget wisely — you can't go below zero.</span>
          </div>
        </div>
      </div>

      <h3 class="bookie-rules-subheading">Strategy</h3>
      <p class="bookie-rules-body">
        Unlike the League Table, Richest Gooner rewards risk management. Chasing long shots can win you a fortune or wipe you out. Steady, disciplined betting often beats going all-in.
      </p>
    </div>

    {{! General rules }}
    <div class="bookie-rules-section bookie-rules-section--general">
      <h3 class="bookie-rules-subheading">General rules</h3>
      <ul class="bookie-rules-list">
        <li>One bet per event, per person. No changing your mind after the deadline.</li>
        <li>You can cancel a pending bet before the event deadline — your coins are refunded.</li>
        <li>Admins set the odds and settle events. Results are final once settled.</li>
        <li>This is for fun only. Coins have no monetary value.</li>
      </ul>
    </div>

  </div>
  {{/if}}

  {{! ══════════════════════════════════════════════════ }}
  {{! PANEL: Admin (staff only)                          }}
  {{! ══════════════════════════════════════════════════ }}
  {{#if (and (eq this.activeTab "admin") this.currentUser.staff)}}
  <div class="bookie-panel bookie-admin-panel">

    <div class="bookie-standings-tabs bookie-admin-subtabs">
      <button type="button"
              class="bookie-standings-tab bookie-admin-subtab {{if (eq this.adminSubTab 'events') 'active'}}"
              {{on "click" (fn this.setAdminSubTab "events")}}>
        Events
      </button>
      <button type="button"
              class="bookie-standings-tab bookie-admin-subtab {{if (eq this.adminSubTab 'management') 'active'}}"
              {{on "click" (fn this.setAdminSubTab "management")}}>
        Management
      </button>
    </div>

    {{#if this.adminError}}
      <div class="bookie-error">{{this.adminError}}</div>
    {{/if}}

    {{#if (eq this.adminSubTab "events")}}
    <h2>Create new event</h2>
    <div class="bookie-admin-form">
      <div class="bookie-form-row">
        <label>Home team</label>
        <input class="bookie-input" type="text"
               value={{this.nmHomeTeam}} placeholder="e.g. Arsenal"
               {{on "input" (fn this.updateField "nmHomeTeam")}} />
      </div>
      <div class="bookie-form-row">
        <label>Away team</label>
        <input class="bookie-input" type="text"
               value={{this.nmAwayTeam}} placeholder="e.g. Chelsea"
               {{on "input" (fn this.updateField "nmAwayTeam")}} />
      </div>
      <div class="bookie-form-row">
        <label>Title (optional — auto-generated if empty)</label>
        <input class="bookie-input" type="text"
               value={{this.nmTitle}} placeholder="e.g. Arsenal vs Chelsea — PL GW30"
               {{on "input" (fn this.updateField "nmTitle")}} />
      </div>
      <div class="bookie-form-row bookie-odds-form-row">
        <div>
          <label>Odds: home win</label>
          <input class="bookie-input bookie-odds-input" type="number"
                 step="0.05" min="1.01"
                 value={{this.nmOddsHome}}
                 {{on "input" (fn this.updateField "nmOddsHome")}} />
        </div>
        <div>
          <label>Odds: draw</label>
          <input class="bookie-input bookie-odds-input" type="number"
                 step="0.05" min="1.01"
                 value={{this.nmOddsDraw}}
                 {{on "input" (fn this.updateField "nmOddsDraw")}} />
        </div>
        <div>
          <label>Odds: away win</label>
          <input class="bookie-input bookie-odds-input" type="number"
                 step="0.05" min="1.01"
                 value={{this.nmOddsAway}}
                 {{on "input" (fn this.updateField "nmOddsAway")}} />
        </div>
      </div>
      <div class="bookie-form-row">
        <label>Deadline (kick-off time)</label>
        <input class="bookie-input" type="datetime-local"
               value={{this.nmDeadline}}
               {{on "input" (fn this.updateField "nmDeadline")}} />
        <span class="bookie-form-help">
          Saved from your local timezone: {{this.browserTimeZone}}
        </span>
      </div>
      <button class="btn btn-primary" {{on "click" this.createMatch}}>
        Create event
      </button>
    </div>

    <h2 class="bookie-section-title">Open events</h2>
    {{#if this.adminMatches.length}}
      {{#each this.adminMatches as |match|}}
        <div class="bookie-admin-match-row">
          {{#if (eq this.editingMatchId match.id)}}
            <div class="bookie-admin-edit-grid">
              <div class="bookie-form-row">
                <label>Home team</label>
                <input class="bookie-input" type="text"
                       value={{this.emHomeTeam}}
                       {{on "input" (fn this.updateField "emHomeTeam")}} />
              </div>
              <div class="bookie-form-row">
                <label>Away team</label>
                <input class="bookie-input" type="text"
                       value={{this.emAwayTeam}}
                       {{on "input" (fn this.updateField "emAwayTeam")}} />
              </div>
              <div class="bookie-form-row bookie-admin-edit-title">
                <label>Title</label>
                <input class="bookie-input" type="text"
                       value={{this.emTitle}}
                       {{on "input" (fn this.updateField "emTitle")}} />
              </div>
              <div class="bookie-form-row">
                <label>Home odds</label>
                <input class="bookie-input bookie-odds-input" type="number"
                       step="0.05" min="1.01"
                       value={{this.emOddsHome}}
                       {{on "input" (fn this.updateField "emOddsHome")}} />
              </div>
              <div class="bookie-form-row">
                <label>Draw odds</label>
                <input class="bookie-input bookie-odds-input" type="number"
                       step="0.05" min="1.01"
                       value={{this.emOddsDraw}}
                       {{on "input" (fn this.updateField "emOddsDraw")}} />
              </div>
              <div class="bookie-form-row">
                <label>Away odds</label>
                <input class="bookie-input bookie-odds-input" type="number"
                       step="0.05" min="1.01"
                       value={{this.emOddsAway}}
                       {{on "input" (fn this.updateField "emOddsAway")}} />
              </div>
              <div class="bookie-form-row bookie-admin-edit-title">
                <label>Deadline (kick-off time)</label>
                <input class="bookie-input" type="datetime-local"
                       value={{this.emDeadline}}
                       {{on "input" (fn this.updateField "emDeadline")}} />
                <span class="bookie-form-help">
                  Saved from your local timezone: {{this.browserTimeZone}}
                </span>
              </div>
              <div class="bookie-admin-edit-actions">
                <button class="btn btn-small btn-danger"
                        {{on "click" (fn this.deleteMatch match)}}>
                  Delete event
                </button>
                <button class="btn btn-primary btn-small"
                        {{on "click" (fn this.saveMatch match)}}>
                  Save changes
                </button>
                <button class="btn btn-small"
                        {{on "click" this.cancelEditingMatch}}>
                  Cancel
                </button>
              </div>
            </div>
          {{else}}
            <div class="bookie-admin-card-layout">
              <div class="bookie-admin-match-info">
                <strong class="bookie-admin-match-title">{{match.title}}</strong>
                <span class="bookie-admin-odds">
                  Home {{match.odds_home}} · Draw {{match.odds_draw}} · Away {{match.odds_away}}
                </span>
                <span class="bookie-admin-stats">
                  {{match.total_bets}} bets · {{match.total_coins}} {{this.currency}}
                  &nbsp;(🏠 {{match.bets_home}} · ➡️ {{match.bets_draw}} · ✈️ {{match.bets_away}})
                </span>
                <span class="bookie-admin-deadline">Deadline: {{match.formattedDeadline}}</span>
              </div>

              <div class="bookie-admin-card-controls">
                <button class="bookie-admin-icon-btn"
                        type="button"
                        style="background: transparent; border: 1px solid var(--primary-low-mid, var(--primary-low)); border-radius: 2px; box-shadow: none; color: var(--primary-medium);"
                        title="Edit event"
                        {{on "click" (fn this.startEditingMatch match)}}>
                  {{d-icon "pencil-alt"}}
                </button>

                <div class="bookie-admin-controls-separator"></div>

                <div class="bookie-admin-actions">
                  <span class="bookie-settle-label">Settle as:</span>
                  <div class="bookie-admin-settle-buttons">
                    <button class="bookie-admin-settle-btn bookie-admin-settle-btn-home"
                            style="border-radius: 2px; font-weight: 400;"
                            {{on "click" (fn this.settleMatch match "home")}}>
                      Home wins
                    </button>
                    <button class="bookie-admin-settle-btn bookie-admin-settle-btn-draw"
                            style="border-radius: 2px; font-weight: 400;"
                            {{on "click" (fn this.settleMatch match "draw")}}>
                      Draw
                    </button>
                    <button class="bookie-admin-settle-btn bookie-admin-settle-btn-away"
                            style="border-radius: 2px; font-weight: 400;"
                            {{on "click" (fn this.settleMatch match "away")}}>
                      Away wins
                    </button>
                  </div>
                </div>
              </div>
            </div>
          {{/if}}
        </div>
      {{/each}}
    {{else}}
      <div class="bookie-empty">No open events to manage.</div>
    {{/if}}
    {{/if}}

    {{#if (eq this.adminSubTab "management")}}
    <div class="bookie-season-section bookie-season-section-first"
         style="margin-top: 0; padding-top: 0; border-top: 0;">
      <h2 class="bookie-section-title">Admin tools</h2>
      <div class="bookie-season-card">
        <div class="bookie-season-info">
          <span class="bookie-season-label">Bulk grant</span>
          <span class="bookie-season-key">All players</span>
        </div>
        <p class="bookie-season-desc">
          Give every existing Bookie player the same amount of {{this.currency}}.
          Useful for compensation, resets or one-off boosts across the whole game.
        </p>
        <div class="bookie-admin-form bookie-admin-form-compact">
          <div class="bookie-form-row">
            <label>Coins to grant</label>
            <input class="bookie-input" type="number" min="1" step="1"
                   value={{this.grantAllAmount}} placeholder="e.g. 100"
                   {{on "input" (fn this.updateField "grantAllAmount")}} />
          </div>
          <div class="bookie-form-row">
            <label>Reason (optional)</label>
            <input class="bookie-input" type="text"
                   value={{this.grantAllReason}} placeholder="e.g. Goodwill bonus after a bug"
                   {{on "input" (fn this.updateField "grantAllReason")}} />
            <span class="bookie-form-help">
              This reason will be saved in every player's wallet log.
            </span>
          </div>
          <button class="btn btn-primary"
                  disabled={{this.grantAllLoading}}
                  {{on "click" this.grantAllPlayers}}>
            {{#if this.grantAllLoading}}
              Granting coins…
            {{else}}
              Grant coins to all players
            {{/if}}
          </button>
        </div>
      </div>
    </div>

    <div class="bookie-season-section">
      <h2 class="bookie-section-title">Period management</h2>
      <div class="bookie-season-card">
        {{#if this.closablePeriodLabel}}
          <div class="bookie-season-info">
            <span class="bookie-season-label">Finished period</span>
            <span class="bookie-season-key">{{this.closablePeriodLabel}}</span>
          </div>

          {{#if this.closablePeriodClosed}}
            <div class="bookie-season-closed-notice">
              ✅ Period {{this.closablePeriodLabel}} is already closed.
            </div>
          {{else}}
            <p class="bookie-season-desc">
              This snapshots the top 3 for the finished League Table period so it appears under previous winners.
            </p>
            <button class="btn btn-primary"
                    disabled={{this.periodClosing}}
                    {{on "click" this.closeCurrentPeriod}}>
              {{#if this.periodClosing}}
                Closing period…
              {{else}}
                Close period {{this.closablePeriodLabel}}
              {{/if}}
            </button>
          {{/if}}
        {{else}}
          <p class="bookie-season-desc">
            No finished period is waiting to be closed right now.
          </p>
        {{/if}}
      </div>
    </div>

    {{! ── Season management ── }}
    <div class="bookie-season-section">
      <h2 class="bookie-section-title">Season management</h2>
      <div class="bookie-season-card">
        <div class="bookie-season-info">
          <span class="bookie-season-label">Current season</span>
          <span class="bookie-season-key">{{this.seasonKey}}</span>
        </div>
        {{#if this.seasonAlreadyClosed}}
          <div class="bookie-season-closed-notice">
            ✅ Season {{this.seasonKey}} is closed. Standings have been saved.
            Start a new season by clicking End Season at the end of next season.
          </div>
        {{else}}
          <p class="bookie-season-desc">
            Closing the season saves the Richest Gooner top 3 as permanent winners
            and resets all wallet balances to the starting amount.
            The League Table resets automatically every two months.
          </p>
          <button class="btn btn-danger bookie-end-season-btn"
                  disabled={{this.seasonLoading}}
                  {{on "click" this.endSeason}}>
            {{#if this.seasonLoading}}
              Closing season…
            {{else}}
              🏁 End season {{this.seasonKey}}
            {{/if}}
          </button>
        {{/if}}
      </div>
    </div>
    {{/if}}

  </div>
  {{/if}}

</div>
